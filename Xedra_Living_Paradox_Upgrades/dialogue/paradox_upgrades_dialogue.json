  {
    "type": "talk_topic",
    "id": "TALK_XEDRA_PARADOX_UPGRADES_MAIN",
    "dynamic_line": "Paradox Upgrades — Improve your Living Paradox through insight.\n\nCurrent Insight: <u_val:xedra_chronomancer_insight_count>",
    "responses": [
      {
        "condition": { "math": [ "u_has_trait('XEDRA_SLEEP_ACCEL_3')" ] },
        "text": "Sleep Acceleration: Maxed (Level 3)",
        "topic": "TALK_XEDRA_PARADOX_UPGRADES_MAIN"
      },
      {
        "condition": { "math": [ "!u_has_trait('XEDRA_SLEEP_ACCEL_1')" ] },
        "text": "Sleep Acceleration Level 1 (100 Insight) — Reduce sleep time by 10%",
        "topic": "TALK_XEDRA_PURCHASE_SLEEP_1"
      },
      {
        "condition": {
          "and": [
            { "math": [ "u_has_trait('XEDRA_SLEEP_ACCEL_1')" ] },
            { "math": [ "!u_has_trait('XEDRA_SLEEP_ACCEL_2')" ] }
          ]
        },
        "text": "Sleep Acceleration Level 2 (200 Insight) — Reduce sleep time by 20% total",
        "topic": "TALK_XEDRA_PURCHASE_SLEEP_2"
      },
      {
        "condition": {
          "and": [
            { "math": [ "u_has_trait('XEDRA_SLEEP_ACCEL_2')" ] },
            { "math": [ "!u_has_trait('XEDRA_SLEEP_ACCEL_3')" ] }
          ]
        },
        "text": "Sleep Acceleration Level 3 (300 Insight) — Reduce sleep time by 30% total",
        "topic": "TALK_XEDRA_PURCHASE_SLEEP_3"
      },
      {
        "text": "Insight Grip (extend insight-from-kills duration 100% per level)",
        "effect": [
          {
            "math": [
              "u_chronomancer_menu_insight_cost = 100 + 100 * u_val('xedra_insight_grip_level')"
            ]
          },
          {
            "set_string_var": "Insight Grip",
            "target_var": { "context_val": "chronomancer_menu_choice_name" }
          },
          {
            "set_string_var": "Increases time to gain insight from kills by 100% per level. Max level = Intelligence.",
            "target_var": { "context_val": "chronomancer_menu_choice_description" }
          },
          {
            "set_string_var": "xedra_insight_grip",
            "target_var": { "context_val": "chronomancer_menu_choice_id" }
          },
          {
            "set_string_var": "Requires <u_val:chronomancer_menu_insight_cost> Insight. Max level = Intelligence (<u_val:intelligence>).",
            "target_var": { "context_val": "chronomancer_menu_requirement_description" }
          }
        ],
        "topic": "TALK_XEDRA_UPGRADE_PURCHASE_INSIGHT_GRIP"
      },
      { "text": "Go Back.", "topic": "TALK_CHRONOMANCER_MAIN_OR_UPGRADES" },
      { "text": "Quit.", "topic": "TALK_DONE" }
    ]
  },
  {
